# Ключ Google Gemini API для генерации тестов (ИИ).
# Получить ключ: https://aistudio.google.com/apikey
# Скопируйте этот файл в .env.local и подставьте свои ключи.
GEMINI_API_KEY=ваш_ключ_здесь

# URL задеплоенного Google Apps Script (бэкенд).
# Развернуть: Apps Script → Развернуть → Новое развёртывание → Веб-приложение.
APPS_SCRIPT_URL=https://script.google.com/macros/s/ВАШ_ДЕПЛОЙ_ID/exec
